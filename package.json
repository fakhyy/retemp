{
  "name": "@fakhyy/retemp",
  "type": "module",
  "version": "0.1.0",
  "license": "MIT",
  "description": "Type-safe email templates for React Email and Resend with automatic prop inference.",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "changeset publish"
  },
  "dependencies": {
    "@react-email/render": "^2"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/bun": "latest",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19",
    "tsdown": "^0.22.3",
    "typescript": "^5.9.2"
  },
  "peerDependencies": {
    "resend": "^6",
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/fakhyy/retemp.git"
  },
  "homepage": "https://retemp.vercel.app",
  "bugs": {
    "url": "https://github.com/fakhyy/retemp/issues"
  },
  "keywords": [
    "resend",
    "react-email",
    "email",
    "typescript",
    "jsx",
    "templates"
  ],
  "packageManager": "bun@1.3.14",
  "sideEffects": false
}
